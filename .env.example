# Pixel Agents - OpenClaw Edition
# Copy to .env and fill in your configuration.

# Server port (default: 19100)
PORT=19100

# ── OpenClaw Gateway ─────────────────────────────────────────────────────────


# Gateway hostname (default: localhost)
OPENCLAW_HOST=localhost

# Gateway port (default: 18789)
OPENCLAW_PORT=18789

# Required: your gateway auth token from ~/.openclaw/openclaw.json
OPENCLAW_TOKEN=

# Optional: read token from a file instead of env var (prevents token leak via
# /proc/[pid]/environ). If set, takes precedence over OPENCLAW_TOKEN.
# OPENCLAW_TOKEN_FILE=/run/secrets/openclaw-token

# WebSocket scheme for gateway connection: ws (default) or wss
# Use wss when the gateway is on a remote host to encrypt the token in transit.
# OPENCLAW_SCHEME=wss

# ── Security (optional, recommended for production) ─────────────────────────


# API auth token. If set, all /api/* endpoints and the /ws WebSocket require
# an Authorization: Bearer <token> header. Recommended when exposing the server
# beyond localhost.
# API_TOKEN=your-api-secret

# TLS cert and key paths. If both are set, the server serves HTTPS/WSS instead
# of HTTP/WS. Generate with:
#   openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
#     -keyout key.pem -out cert.pem -subj "/CN=localhost"
# TLS_CERT=/etc/pixel-agents/cert.pem
# TLS_KEY=/etc/pixel-agents/key.pem
